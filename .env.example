# Fitbit OAuth configuration
# Required only if using Fitbit activity sync.
FITBIT_CLIENT_ID=your_fitbit_client_id
FITBIT_REDIRECT_URI=http://127.0.0.1:8080/

# Open-Meteo location configuration
# Keep real coordinates in your local .env file only.
# Do not commit .env.

RIGLOG_OPEN_METEO_HOME_LATITUDE=your_home_latitude
RIGLOG_OPEN_METEO_HOME_LONGITUDE=your_home_longitude

RIGLOG_OPEN_METEO_PARTNER_HOME_LATITUDE=your_partner_home_latitude
RIGLOG_OPEN_METEO_PARTNER_HOME_LONGITUDE=your_partner_home_longitude
